{
  "name": "tex-db",
  "version": "2.0.0",
  "description": "CSE JnU Question Bank - A comprehensive study resource platform",
  "main": "index.js",
  "scripts": {
    "validate": "node scripts/validate.js",
    "validate-json": "node scripts/validate-json.js",
    "check-structure": "node scripts/check-structure.js",
    "generate-index": "node scripts/generate-index.js",
    "lint-md": "markdownlint **/*.md",
    "validate-all": "npm run validate-json && npm run check-structure && npm run lint-md",
    "migrate": "node scripts/migrate.js",
    "serve": "http-server . -p 8080 -c-1",
    "test": "jest",
    "update-readme-content": "node scripts/update-readme-content-count.js",
    "update-contributors": "node scripts/update-contributors.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cse-jnu/tex-db.git"
  },
  "keywords": [
    "education",
    "question-bank",
    "study-materials",
    "cse",
    "jnu",
    "bangladesh"
  ],
  "author": "CSE JnU Community",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cse-jnu/tex-db/issues"
  },
  "homepage": "https://github.com/cse-jnu/tex-db#readme",
  "devDependencies": {
    "ajv": "^8.12.0",
    "glob": "^10.3.10",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "markdownlint": "^0.31.1",
    "markdownlint-cli": "^0.37.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
